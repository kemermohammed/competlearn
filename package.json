{
  "name": "competlearn",
  "version": "1.0.0",
  "private": true,
  "description": "competiLearn — AI-powered competitor intelligence feed",
  "scripts": {
    "install:all": "npm install && npm --prefix server install && npm --prefix web install",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --prefix server run dev",
    "dev:web": "npm --prefix web run dev",
    "start": "concurrently -n server,web -c blue,magenta \"npm --prefix server start\" \"npm --prefix web start\"",
    "build": "npm --prefix web run build",
    "test:cala": "node server/test-cala.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
