# Cala API key — used for verified company facts (https://docs.cala.ai)
CALA_API_KEY=

# OpenAI API key — optional. If empty, the app runs in mock AI mode.
OPENAI_API_KEY=

# Port the Express backend listens on
PORT=3000

# Base URL the frontend uses to reach the backend (cross-origin, CORS-enabled).
# Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_API_BASE=http://localhost:3000
